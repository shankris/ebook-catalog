        color: var(--bds-color-functional-neutral-on-surface);
    }

    .compact.secondaryText {
        color: var(--bds-color-functional-neutral-on-surface-variant);
    }

    .compact.primaryText.primaryTextOnly {
        ${Zi(2)};
    }

    .boldText {
