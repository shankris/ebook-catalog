    :host {
        font-family: var(--bds-font-family-functional-body);
    }

    .bookTitleContent {
        min-width: min(140px, 100%);
    }

    a {
        text-decoration: none;
    }

    .primaryText,
    .primaryText a {
        color: var(--bds-color-functional-neutral-on-surface);
