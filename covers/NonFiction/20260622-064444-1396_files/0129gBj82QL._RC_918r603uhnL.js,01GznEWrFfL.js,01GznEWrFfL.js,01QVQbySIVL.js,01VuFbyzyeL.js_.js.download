        border-right: var(
            --box-border-right,
            var(--bds-size-line-weight-small) solid
                var(--box-border-color, var(--bds-color-functional-neutral-surface-container))
        );
    }

    /* Text alignment */
    .textAlign-left .bds-box-inner {
        text-align: left;
    }

    .textAlign-center .bds-box-inner {
        text-align: center;
    }

    .textAlign-right .bds-box-inner {
        text-align: right;
