        min-height: var(--_step-line-min-height);
        flex-grow: 1;
        background-color: var(--bds-color-functional-supplemental-alert-information);
        margin: 0;
        padding: 0;
    }

    .step-content {
        flex-grow: 1;
        margin-top: var(--_step-content-offset);
    }
